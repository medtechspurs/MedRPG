  "states": {
    "stable": "Uncomplicated appendicitis. AP > 50. Patient alert, uncomfortable, classic presentation.",
    "perforated": "Perforated appendicitis. AP <= 50. Increased toxicity, peritoneal signs, worsening systemic illness.",
    "septic_shock": "Septic shock from perforated appendicitis. AP <= 30 or >= 7 harm points. Hemodynamic instability, end-organ dysfunction.",
    "coma_fail": "Multi-organ failure / imminent death. AP = 0. Extreme lab derangements."
  },
  "clinical_notes": {
    "general": "Ranges represent realistic clinical variation for acute appendicitis in a 22yo male. Values are randomized within range each playthrough for replayability.",
    "urinalysis": "Mild UA abnormalities in appendicitis reflect proximity of inflamed appendix to right ureter \u2014 important for DDx (distinguishing from UTI, kidney stone). Should NOT be impressive enough to redirect diagnosis.",
    "negative_findings": "Normal lipase/amylase (rules out pancreatitis), normal LFTs (rules out cholecystitis/hepatitis), normal troponin, negative urine/serum hCG (rules out ectopic pregnancy in females \u2014 Marcus is male so hCG is negative) are important DDx findings.",
    "blood_cultures": "Blood cultures return no growth in stable/perforated states; may return gram-negative organisms in septic_shock and coma_fail.",
    "culture_delay": "Blood and urine cultures have 48-120h result delay. Include initial 'Pending' state in UI."
  },
