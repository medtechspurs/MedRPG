{
  "schema_version": "1.0",
  "description": "Master medication catalog. The engine loads ONLY this file at startup. The 23 category files in data/medications/source/ (medications_antibiotics.json, medications_analgesics.json, etc.) are reference / authoring source — they are NOT loaded by the engine. To expand the v1 set, copy entries from those source files into this file, add the engine-required fields (canonical_id, ap_cost, peripheral_extravasation_risk), then commit.",

  "schema_notes": {
    "id": "Unique identifier for this medication entry. Used as the primary key.",
    "canonical_id": "The drug's true identity. Multiple entries (e.g. ondansetron in GI vs ondansetron_chemo in Other) share the same canonical_id so the engine treats them as one drug for ordering, allergy checks, and 'already given' tracking. For most v1 entries canonical_id == id.",
    "category_id": "Drives which Browse Categories tab the entry appears under. Mirrors the source file it came from.",
    "ap_cost": "Per-drug global cost. Same regardless of route. Per-condition overrides may exist in the future.",
    "routes": "Available routes for this drug. The medication confirmation popup builds route buttons from this list, intersected with what's currently feasible (e.g. IV routes only shown if patient has vascular access).",
    "allergy_class": "Categorical allergy bucket. If patient_allergies in the condition file contains a matching value, the engine fires the allergy warning popup. Null = no relevant allergy class.",
    "peripheral_extravasation_risk": "low | moderate | high. Currently informational only — wired into the IV Stage F extravasation roll when that ships. Do not remove.",
    "semantic_tags": "Free-text bag used by the Ask MEDDY filter. LLM analyzes player question, returns a tag list, engine filters medications by tag overlap.",
    "ap_cost_scale": "Routine meds (most antibiotics, analgesics, antiemetics, fluids, sedatives, paralytics, reversal): 1 AP. Vasopressors and inotropes: 2 AP. Blood products: 2 AP (none in v1). Thrombolytics: 4-5 AP (none in v1)."
  },

