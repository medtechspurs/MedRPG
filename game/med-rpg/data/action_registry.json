      "label": "Rapid Stability Assessment",
      "icon": "icon_stability.png",
      "input_method": "single_button",
      "llm_parses": false,
      "ap_cost": 2,
      "note": "Quick assessment of mental status, perfusion, and respiratory effort. Single click — no sub-options. Bonus point available in perforated and septic shock states if clicked before expiry exam components."
    },
    "diagnosis": {
      "label": "Diagnosis",
      "icon": "icon_diagnosis.png",
      "input_method": "free_text",
      "llm_parses": true,
      "llm_instruction": "Evaluate player diagnosis leniently. Match clinical intent, not exact wording. Accept synonyms, abbreviations, and common clinical shorthand.",
      "ap_cost_correct": 0,
      "ap_cost_incorrect": 2,
      "note": "Available at any time. Correct diagnosis awards bonus points but does not end encounter — treatment still required. Multiple attempts allowed — bonus points still awarded after incorrect guesses."
    }
