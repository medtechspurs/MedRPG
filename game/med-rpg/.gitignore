# Godot 4 .gitignore

# Godot-specific ignores
.godot/
*.uid

# Imported assets (generated by Godot, do not commit)
.import/
*.import

# Export files
*.apk
*.aab
*.ipa
*.pck
*.zip
*.exe
*.x86_64
*.arm64-v8a

# Mono/C# specific (not using, but just in case)
.mono/
data_*/
mono_crash.*.json

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# VS Code
.vscode/

# JetBrains
.idea/

# Temp files
*.tmp
*.bak
*.swp
